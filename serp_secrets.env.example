# ====================================================================
# ERGO Brand Bidding – API-Zugang
# --------------------------------------------------------------------
# 1. Diese Datei kopieren und in  serp_secrets.env  umbenennen
#    (OHNE .example). Die echte Datei NICHT teilen / nicht ins Git.
# 2. Provider wählen und den passenden Key eintragen.
# 3. Das Scan-Script liest diese Datei automatisch ein.
# ====================================================================

# Welcher Anbieter? "serper" (Standard) oder "dataforseo"
SERP_PROVIDER=serper

# --- Option A: Serper  (https://serper.dev) -------------------------
# Hinweis: "Serper" (serper.dev), NICHT das gleichnamige "SerpApi"
# (serpapi.com). Das Script nutzt Serper. Key im Serper-Dashboard.
SERPER_API_KEY=hier_deinen_serper_key_eintragen

# --- Option B: DataForSEO (https://dataforseo.com) ------------------
# Nur nötig, wenn SERP_PROVIDER=dataforseo
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
